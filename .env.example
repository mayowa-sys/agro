# ─────────────────────────────────────────────────────────
# AGRO — environment template
# Copy this to .env and fill in real values.
# NEVER commit .env (it's in .gitignore).
# ─────────────────────────────────────────────────────────

# Postgres
DATABASE_URL=postgresql://agro:agro@localhost:5432/agro

# Redis
REDIS_URL=redis://localhost:6379

# Squad
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_SECRET_KEY=
SQUAD_PUBLIC_KEY=
SQUAD_WEBHOOK_SECRET=
SQUAD_MERCHANT_ID=
SQUAD_MOCK_MODE=true

# Africa's Talking
AT_USERNAME=
AT_API_KEY=
AT_SHORTCODE=
AT_SENDER_ID=AGRO

# AI Service
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TOKEN=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend
VITE_API_URL=http://localhost:3000
VITE_DEMO_MODE=true

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
DEMO_RESET_TOKEN=
