generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FARMER
  AGGREGATOR
  ADMIN
  LABOURER
}

enum CropType {
  YAM
  CASSAVA
  MAIZE
  RICE
  TOMATO
  COCOA
  SESAME
  OTHER
}

enum Language {
  EN
  PIDGIN
  HAUSA
  YORUBA
  IGBO
}

enum AccountPurpose {
  WORKING
  BILLS
  NEXT_SEASON
  LABOUR_SAVINGS
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionSource {
  HARVEST_PAYMENT
  SPLIT_TRANSFER
  INPUT_DISBURSEMENT
  INPUT_REPAYMENT
  FACTORING_ADVANCE
  FACTORING_REPAYMENT
  EXTERNAL
  UNKNOWN
}

enum DeferralStatus {
  PENDING
  ACTIVE
  REPAID
  DEFAULTED
  CANCELLED
}

enum FactoringStatus {
  REQUESTED
  ADVANCED
  REPAID
  OVERDUE
}

enum BriefChannel {
  SMS
  IN_APP
}

model User {
  id          String      @id @default(cuid())
  phone       String      @unique
  hashedPin   String?
  role        Role        @default(FARMER)
  language    Language    @default(EN)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  farmer      Farmer?
  aggregator  Aggregator?
  labourer    Labourer?
  virtualAccounts VirtualAccount[]
}

model Farmer {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id])
  name                String
  cropType            CropType
  region              String
  zone                String?
  plantingDate        DateTime?
  expectedHarvestDate DateTime?
  hashedBvn           String?
  cooperativeId       String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  virtualAccounts     VirtualAccount[]
  splitRule           SplitRule?
  forecasts           Forecast[]
  cashGaps            CashGap[]
  inputDeferrals      InputDeferral[]
  factoringAdvances   FactoringAdvance[]
  weeklyBriefs        WeeklyBrief[]
  liberationLogs      LiberationLog[]
  jobs                Job[]
}

model Aggregator {
  id                String             @id @default(cuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id])
  businessName      String
  contactEmail      String
  squadAccountId    String?
  createdAt         DateTime           @default(now())
  factoringAdvances FactoringAdvance[]
}

model VirtualAccount {
  id                 String         @id @default(cuid())
  farmerId           String?
  farmer             Farmer?        @relation(fields: [farmerId], references: [id])
  userId             String?
  user               User?          @relation(fields: [userId], references: [id])
  squadAccountNumber String         @unique
  squadCustomerId    String
  bankName           String
  purpose            AccountPurpose
  cachedBalance      BigInt         @default(0)
  balanceKobo        BigInt         @default(0)
  createdAt          DateTime       @default(now())
  transactions       Transaction[]

  @@index([farmerId, purpose])
  @@index([userId, purpose])
}

model SplitRule {
  id            String   @id @default(cuid())
  farmerId      String   @unique
  farmer        Farmer   @relation(fields: [farmerId], references: [id])
  workingPct    Int      @default(60)
  billsPct      Int      @default(25)
  nextSeasonPct Int      @default(15)
  active        Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

model Transaction {
  id                String            @id @default(cuid())
  virtualAccountId  String
  virtualAccount    VirtualAccount    @relation(fields: [virtualAccountId], references: [id])
  squadReference    String            @unique
  amount            BigInt
  type              TransactionType
  source            TransactionSource @default(UNKNOWN)
  occurredAt        DateTime
  rawWebhookPayload Json
  processed         Boolean           @default(false)
  createdAt         DateTime          @default(now())

  @@index([virtualAccountId, occurredAt])
}

model Forecast {
  id           String          @id @default(cuid())
  farmerId     String
  farmer       Farmer          @relation(fields: [farmerId], references: [id])
  generatedAt  DateTime        @default(now())
  modelVersion String
  horizonDays  Int             @default(90)
  events       ForecastEvent[]

  @@index([farmerId, generatedAt])
}

model ForecastEvent {
  id             String   @id @default(cuid())
  forecastId     String
  forecast       Forecast @relation(fields: [forecastId], references: [id])
  expectedDate   DateTime
  expectedAmount BigInt
  type           String
  category       String
  confidence     Float
  reasonsJson    Json

  @@index([forecastId, expectedDate])
}

model CashGap {
  id         String   @id @default(cuid())
  farmerId   String
  farmer     Farmer   @relation(fields: [farmerId], references: [id])
  startDate  DateTime
  endDate    DateTime
  gapAmount  BigInt
  status     String
  detectedAt DateTime @default(now())
}

model Supplier {
  id                 String          @id @default(cuid())
  name               String
  contactPhone       String
  squadAccountNumber String
  region             String
  active             Boolean         @default(true)
  inputDeferrals     InputDeferral[]
}

model InputDeferral {
  id              String         @id @default(cuid())
  farmerId        String
  farmer          Farmer         @relation(fields: [farmerId], references: [id])
  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  amount          BigInt
  agroFee         BigInt
  status          DeferralStatus @default(PENDING)
  squadMandateId  String?
  expectedRepayBy DateTime?
  disbursedAt     DateTime?
  repaidAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model FactoringAdvance {
  id                      String          @id @default(cuid())
  aggregatorId            String
  aggregator              Aggregator      @relation(fields: [aggregatorId], references: [id])
  farmerId                String
  farmer                  Farmer          @relation(fields: [farmerId], references: [id])
  amount                  BigInt
  fee                     BigInt
  status                  FactoringStatus @default(REQUESTED)
  advancedAt              DateTime?
  expectedRepayBy         DateTime?
  repaidAt                DateTime?
  squadAdvanceTransferRef String?
  squadRepaymentRef       String?
  createdAt               DateTime        @default(now())
  liberationLog           LiberationLog?
}

model LiberationLog {
  id                     String           @id @default(cuid())
  farmerId               String
  farmer                 Farmer           @relation(fields: [farmerId], references: [id])
  factoringAdvanceId     String           @unique
  factoringAdvance       FactoringAdvance @relation(fields: [factoringAdvanceId], references: [id])
  counterfactualLossKobo BigInt
  loggedAt               DateTime         @default(now())
  source LiberationSource @default(MIDDLEMAN_DISCOUNT_AVOIDED)
}

model WeeklyBrief {
  id           String       @id @default(cuid())
  farmerId     String
  farmer       Farmer       @relation(fields: [farmerId], references: [id])
  weekOf       DateTime
  contentText  String
  channel      BriefChannel
  sentAt       DateTime?
  delivered    Boolean      @default(false)
  errorMessage String?
  createdAt    DateTime     @default(now())

  @@unique([farmerId, weekOf, channel])
}

model CropPlaybook {
  id                  String   @id @default(cuid())
  name                String   @unique
  cropType            CropType
  description         String
  baselineSeasonality Json
  active              Boolean  @default(true)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  metadata   Json
  occurredAt DateTime @default(now())
}

enum LiberationSource {
  MIDDLEMAN_DISCOUNT_AVOIDED
  CASH_ON_DAY_PREMIUM_CAPTURED
}

model Labourer {
  id                        String    @id @default(cuid())
  userId                    String    @unique
  user                      User      @relation(fields: [userId], references: [id])
  fullName                  String
  region                    String
  state                     String
  latitude                  Float?
  longitude                 Float?
  skills                    String[]
  spokenLanguages           String[]
  reputationTier            Int       @default(1)
  totalGigsCompleted        Int       @default(0)
  totalEarnedKobo           BigInt    @default(0)
  profileEmbedding          String?
  profileEmbeddingUpdatedAt DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  gigs            Gig[]
  ratingsReceived Rating[] @relation("LabourerRated")
  ratingsGiven    Rating[] @relation("LabourerRater")
}

model Job {
  id                            String    @id @default(cuid())
  farmerId                      String
  farmer                        Farmer    @relation(fields: [farmerId], references: [id])
  title                         String
  description                   String?
  skillsRequired                String[]
  expectedDate                  DateTime
  durationDays                  Int       @default(1)
  payAmountKobo                 BigInt
  workersNeeded                 Int       @default(1)
  status                        JobStatus @default(OPEN)
  sourceForecastEventId         String?
  descriptionEmbedding          String?
  descriptionEmbeddingUpdatedAt DateTime?
  demandConfidence              Float?
  demandConsistency             Float?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt

  gigs Gig[]
}

enum JobStatus {
  OPEN
  FILLED
  CANCELLED
  EXPIRED
}

model Gig {
  id                  String       @id @default(cuid())
  jobId               String
  job                 Job          @relation(fields: [jobId], references: [id])
  labourerId          String
  labourer            Labourer     @relation(fields: [labourerId], references: [id])
  agreedAmountKobo    BigInt
  status              GigStatus    @default(ACCEPTED)
  acceptedAt          DateTime     @default(now())
  farmerConfirmedAt   DateTime?
  labourerConfirmedAt DateTime?
  paidAt              DateTime?
  cancelReason        String?
  wageTransferId      String?      @unique
  wageTransfer        WageTransfer? @relation(fields: [wageTransferId], references: [id])

  rating Rating?
}

enum GigStatus {
  ACCEPTED
  FARMER_CONFIRMED_DONE
  LABOURER_CONFIRMED_DONE
  BOTH_CONFIRMED
  PAID
  CLOSED
  CANCELLED
}

model Rating {
  id                    String    @id @default(cuid())
  gigId                 String    @unique
  gig                   Gig       @relation(fields: [gigId], references: [id])
  farmerScoreOfLabourer Int?
  farmerComment         String?
  labourerScoreOfFarmer Int?
  labourerComment       String?
  labourerId            String
  labourer              Labourer  @relation("LabourerRated", fields: [labourerId], references: [id])
  raterLabourerId       String?
  raterLabourer         Labourer? @relation("LabourerRater", fields: [raterLabourerId], references: [id])
  createdAt             DateTime  @default(now())
}

model WageTransfer {
  id                   String             @id @default(cuid())
  gigId                String             @unique
  fromVirtualAccountId String
  toVirtualAccountId   String
  amountKobo           BigInt
  squadTransferRef     String?
  status               WageTransferStatus @default(PENDING)
  errorMessage         String?
  createdAt            DateTime           @default(now())
  succeededAt          DateTime?

  gig Gig?
}

enum WageTransferStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model MatchFeedback {
  id             String   @id @default(cuid())
  jobId          String
  labourerId     String
  matchScore     Float
  wasAccepted    Boolean
  wasCompleted   Boolean?
  farmerRating   Int?
  labourerRating Int?
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?
}
